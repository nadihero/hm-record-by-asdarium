# Database MySQL / MariaDB
DATABASE_HOST="localhost"
DATABASE_USER="root"
DATABASE_PASSWORD=""
DATABASE_NAME="hm_record"
DATABASE_URL="mysql://root:@localhost:3306/hm_record"

# ── Cloudflare R2 Object Storage (WAJIB — foto timesheet 100% di R2) ──
# Cloudflare Dashboard → R2 → Manage R2 API Tokens
R2_ACCOUNT_ID="your_cloudflare_account_id"
R2_ACCESS_KEY_ID="your_r2_access_key_id"
R2_SECRET_ACCESS_KEY="your_r2_secret_access_key"
R2_BUCKET_NAME="your_r2_bucket_name"

# Public base URL (no trailing slash) — bucket public atau custom domain
# Contoh: https://pub-xxxxx.r2.dev
R2_PUBLIC_URL="https://pub-xxxxx.r2.dev"
